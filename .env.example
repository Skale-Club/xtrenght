# Copy to .env.local and fill in from your Supabase project
# (Dashboard -> Project Settings -> API keys).
#
# .env.local is gitignored. Never commit real keys.

# --- Supabase project ---------------------------------------------------------

# Reference ID, the 20-char string in your dashboard URL:
# https://supabase.com/dashboard/project/<ref>
SUPABASE_PROJECT_REF=

# Project URL, e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Publishable key (formerly "anon"). Safe to expose in the browser: it carries
# no privileges of its own, and RLS decides what each request may read.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Secret key (formerly "service_role"). Bypasses RLS entirely -- server-side
# scripts only. Has no NEXT_PUBLIC_ prefix, which is what keeps Next.js from
# inlining it into client bundles. If this ever leaks, rotate it immediately.
SUPABASE_SECRET_KEY=

# --- Database -----------------------------------------------------------------
# Only needed to run migrations; the app itself never uses these.

# Postgres password. The Supabase CLI reads this variable automatically.
SUPABASE_DB_PASSWORD=

# Project region, e.g. us-west-2.
SUPABASE_DB_REGION=

# Connection string for `supabase db push --db-url "$SUPABASE_DB_URL"`.
# Only migrations use this -- the app talks to PostgREST over HTTP, never to
# Postgres directly.
#
#   postgresql://postgres.<ref>:<password>@aws-<n>-<region>.pooler.supabase.com:5432/postgres
#
# Use the SESSION pooler (port 5432). Supabase recommends the direct connection
# for migrations, but db.<ref>.supabase.co is IPv6-only and most home/office
# networks have no IPv6 route; session mode is the documented IPv4 fallback.
#
# Do NOT substitute the transaction pooler (port 6543) here -- it is what the
# dashboard shows by default, but it does not support prepared statements and
# keeps no session state between queries. It is for serverless/edge workloads.
#
# Two things that bite: the username is postgres.<ref>, not plain postgres, and
# the aws-<n> prefix is not always aws-0. Copy the exact string from
# Dashboard -> Connect -> Session pooler rather than assembling it by hand.
SUPABASE_DB_URL=
