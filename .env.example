# Copy to .env.local and fill in from your Supabase project
# (Dashboard -> Project Settings -> API keys).
#
# .env.local is gitignored. Never commit real keys.

# Project URL, e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Publishable key (formerly "anon"). Safe to expose in the browser: it carries
# no privileges of its own, and RLS decides what each request may read.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Secret key (formerly "service_role"). Bypasses RLS entirely -- server-side
# scripts only. Has no NEXT_PUBLIC_ prefix, which is what keeps Next.js from
# inlining it into client bundles. If this ever leaks, rotate it immediately.
SUPABASE_SECRET_KEY=
